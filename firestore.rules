rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------- Helpers -------
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdminEmail() {
      return isSignedIn() && request.auth.token.email in [
        'balraj@exceed-re.ae',
        'admin@exceed-re.ae'
      ];
    }

    // ------- Agents -------
    match /agents/{userId} {

      // Anyone authenticated can read the agent list (internal team tool).
      allow read: if isSignedIn();

      // A user can create only their own doc, only with an @exceed-re.ae email,
      // and only with status='pending' so admins control activation.
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.auth.token.email.matches('.+@exceed-re[.]ae')
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.status == 'pending';

      // Admins can change any field (mainly status).
      // A normal user can update their own doc but cannot change email/uid/status.
      allow update: if isAdminEmail()
        || (isSignedIn()
            && request.auth.uid == userId
            && request.resource.data.email == resource.data.email
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.status == resource.data.status);

      // Only admins (via Firebase console / future tooling) can delete.
      allow delete: if isAdminEmail();
    }

    // ------- Team config (org chart) -------
    // Single doc at teamConfig/main holds the full team tree.
    // Anyone signed-in can read it; only admins can write.
    match /teamConfig/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdminEmail();
    }

    // ------- Customers -------
    // Doc ID = registration number (e.g. EXC-AB12CD)
    match /customers/{regNumber} {

      // Any signed-in agent or admin can read customers.
      allow read: if isSignedIn();

      // Any signed-in agent or admin can create a customer record;
      // the registeredBy fields must match the caller.
      allow create: if isSignedIn()
        && request.resource.data.regNumber == regNumber
        && request.resource.data.registeredBy == request.auth.uid
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.email is string;

      // Only admins can edit or delete customer records.
      allow update, delete: if isAdminEmail();
    }
  }
}
